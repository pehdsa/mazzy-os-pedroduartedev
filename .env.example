# Copie pra `.env` e preencha. Esse arquivo é só template — não tem segredo.
# O `.env` real NÃO entra no git (já está no .gitignore).

# ============================================
# Meta Graph API — Instagram + Facebook
# ============================================
# Como pegar: ver marketing/automacao-meta-setup.md

# Token da Página FB de longa duração (60 dias)
META_PAGE_ACCESS_TOKEN=

# ID numérico da Página FB (do endpoint /me/accounts)
META_PAGE_ID=

# ID numérico da conta Instagram Business
# (do endpoint /<PAGE_ID>?fields=instagram_business_account)
META_IG_USER_ID=

# ============================================
# Hosting das imagens (URL pública pra Meta API ler)
# ============================================
# Como o MazyOS é repo público, a base é raw.githubusercontent.com
# Formato: https://raw.githubusercontent.com/<usuario>/<repo>/<branch>
ASSETS_BASE_URL=
